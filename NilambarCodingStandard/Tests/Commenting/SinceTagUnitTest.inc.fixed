/**
 * Class Class_one.
 */
abstract class Class_one {
  /**
   * Function.
   *
   * @see text
   */
  public function say_hello() {
    echo "Say hello.";
  }

  /**
   * Another function.
   *
   * @see link
   */
  public static function say_hola() {
    echo "Say hola.";
  }
}

