/**
 * Sample constant.
 */
const MY_CONSTANT = 123;

/**
 * Class Sample_Class.
 */
class Sample_Class {
  public function say_hello() {
    echo "Say hello.";
  }
}

/**
 * MyTrait.
 */
trait MyTrait {
  public function myTraitMethod() {
    echo "Hello from MyTrait!";
	}
}

/**
 * MyInterface.
 */
interface MyInterface {
  public function myMethod();
}

