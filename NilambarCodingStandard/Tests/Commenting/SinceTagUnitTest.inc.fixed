// Closures and anonymous functions must not trigger Missing.
$closure_no_doc = function ( $x ) {
	return $x;
};

/**
 * A closure with a docblock that lacks @since.
 */
$closure_with_doc = function ( $x ) {
	return $x;
};

// Arrow functions are not registered tokens, so they're skipped.
$arrow = fn ( $x ) => $x;

// Anonymous classes (T_ANON_CLASS) are not registered, so they're skipped.
$anon = new class {
	public function hello() {}
};

/**
 * Class with @inheritDoc methods.
 *
 * @since 1.0.0
 */
class Inherit_Sample {
	/**
	 * @inheritDoc
	 */
	public function full_inherit() {}

	/**
	 * Documented method that defers details to parent.
	 *
	 * {@inheritDoc}
	 */
	public function inline_inherit() {}
}

/**
 * Class with @since-tagged property and a property missing @since.
 *
 * @since 1.0.0
 */
class Property_Sample {
	/**
	 * Documented property with @since.
	 *
	 * @since 1.0.0
	 *
	 * @var int
	 */
	public $with_since = 0;

	/**
	 * Documented property without @since.
	 *
	 * @var int
	 */
	public $without_since = 0;

	public $no_doc_block = 0;
}

