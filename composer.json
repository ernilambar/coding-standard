{
  "name": "ernilambar/coding-standard",
  "description": "PHP_CodeSniffer standard for PHP projects.",
  "license": "MIT",
  "type": "phpcodesniffer-standard",
  "keywords": [
    "phpcs",
    "standard"
  ],
  "authors": [
    {
      "name": "Nilambar Sharma",
      "email": "nilambar@outlook.com",
      "homepage": "https://nilambar.net/",
      "role": "Developer"
    }
  ],
  "require": {
    "php": ">=7.4",
    "ext-libxml": "*",
    "ext-tokenizer": "*",
    "ext-xmlreader": "*",
    "squizlabs/php_codesniffer": "^3.13 || ^4.0"
  },
  "require-dev": {
    "php-parallel-lint/php-console-highlighter": "^1.0.0",
    "php-parallel-lint/php-parallel-lint": "^1.3.2",
    "phpcompatibility/php-compatibility": "^10",
    "phpunit/phpunit": "^7.0 || ^8.0 || ^9.0",
    "slevomat/coding-standard": "^8"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "ergebnis/composer-normalize": true
    },
    "platform": {
      "php": "7.4"
    }
  },
  "scripts": {
    "format": "@php ./vendor/bin/phpcbf --report-full --report-summary",
    "lint": [
      "@lint-php",
      "@phpcs"
    ],
    "lint-php": "@php ./vendor/bin/parallel-lint . -p php --show-deprecated --exclude vendor --exclude .git",
    "phpcs": "@php ./vendor/bin/phpcs --report-full --report-summary",
    "test": "@php ./vendor/bin/phpunit --no-coverage"
  }
}
